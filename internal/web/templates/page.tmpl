{{define "page"}}
<!doctype html>
<html lang="ja">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>CryptoBot Console</title>
  <script src="https://cdn.jsdelivr.net/npm/htmx.org@2.0.8/dist/htmx.min.js"></script>
  <style>
    :root {
      --bg: #f4f1ea;
      --panel: #fffdf8;
      --line: #d7d0c3;
      --text: #1f1c18;
      --muted: #6f6558;
      --accent: #0f766e;
      --danger: #b42318;
      --warn: #b54708;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: "Hiragino Sans", "Noto Sans JP", sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at top left, #efe6d8 0, transparent 30%),
        linear-gradient(180deg, #f8f5ef 0%, var(--bg) 100%);
    }
    .shell {
      max-width: 1280px;
      margin: 0 auto;
      padding: 24px;
    }
    .hero {
      display: flex;
      justify-content: space-between;
      gap: 16px;
      align-items: flex-end;
      margin-bottom: 24px;
    }
    .hero h1 { margin: 0; font-size: 32px; }
    .hero p { margin: 8px 0 0; color: var(--muted); }
    .badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 12px;
      border: 1px solid var(--line);
      border-radius: 999px;
      background: rgba(255,255,255,.7);
    }
    .grid {
      display: grid;
      grid-template-columns: 1.2fr 1fr;
      gap: 18px;
    }
    .stack { display: grid; gap: 18px; }
    .panel {
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: 18px;
      padding: 18px;
      box-shadow: 0 10px 30px rgba(31, 28, 24, .05);
    }
    .panel h2, .panel h3 { margin: 0 0 12px; }
    .toolbar, .actions, .order-form {
      display: grid;
      gap: 10px;
    }
    .toolbar { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .order-form { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .field { display: grid; gap: 6px; }
    .field label { font-size: 13px; color: var(--muted); }
    input, select, button {
      width: 100%;
      border-radius: 12px;
      border: 1px solid var(--line);
      padding: 11px 12px;
      font: inherit;
      background: white;
    }
    button {
      cursor: pointer;
      font-weight: 600;
      background: #fff;
    }
    button.primary {
      background: var(--accent);
      border-color: var(--accent);
      color: white;
    }
    button.warn {
      color: var(--warn);
      border-color: rgba(181, 71, 8, .35);
    }
    button.danger {
      color: var(--danger);
      border-color: rgba(180, 35, 24, .35);
    }
    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 14px;
    }
    th, td {
      padding: 10px 8px;
      border-bottom: 1px solid #efe8dc;
      text-align: left;
      vertical-align: top;
    }
    th { color: var(--muted); font-weight: 600; }
    .cards {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 12px;
    }
    .metric {
      padding: 14px;
      border-radius: 14px;
      border: 1px solid #ece3d4;
      background: #fff;
    }
    .metric .label { color: var(--muted); font-size: 13px; }
    .metric .value { margin-top: 8px; font-size: 24px; font-weight: 700; }
    .flash {
      padding: 12px 14px;
      border-radius: 12px;
      border: 1px solid;
      margin-bottom: 16px;
    }
    .flash.success { color: var(--accent); border-color: rgba(15,118,110,.25); background: rgba(15,118,110,.08); }
    .flash.error { color: var(--danger); border-color: rgba(180,35,24,.25); background: rgba(180,35,24,.08); }
    .muted { color: var(--muted); }
    .mono { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; }
    @media (max-width: 980px) {
      .grid { grid-template-columns: 1fr; }
      .toolbar, .order-form, .cards { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 640px) {
      .shell { padding: 14px; }
      .hero { display: block; }
      .toolbar, .order-form, .cards { grid-template-columns: 1fr; }
      table { display: block; overflow-x: auto; white-space: nowrap; }
    }
  </style>
</head>
<body>
  <div class="shell">
    <div class="hero">
      <div>
        <h1>CryptoBot Console</h1>
        <p>Go template と htmx で構成した管理画面</p>
      </div>
      <div class="badge">
        <span>運転モード</span>
        <strong>{{if .DryRun}}DRY RUN{{else}}LIVE{{end}}</strong>
      </div>
    </div>

    <div id="flash"></div>

    <div class="grid">
      <div class="stack">
        <section class="panel">
          <h2>概要</h2>
          <div
            hx-get="/ui/partials/summary"
            hx-trigger="load, refresh-all from:body, every 30s"
            hx-swap="innerHTML"
          >読込中...</div>
        </section>

        <section class="panel">
          <h2>手動操作</h2>
          <div class="toolbar">
            <form hx-post="/ui/actions/price-fetch" hx-target="#flash" hx-swap="innerHTML">
              <button class="primary" type="submit">価格同期</button>
            </form>
            <form hx-post="/ui/actions/order-reconcile" hx-target="#flash" hx-swap="innerHTML">
              <button type="submit">注文同期</button>
            </form>
            <form hx-post="/ui/actions/daily-trade" hx-target="#flash" hx-swap="innerHTML">
              <button class="warn" type="submit">日次売買</button>
            </form>
          </div>
        </section>

        <section class="panel">
          <h2>手動注文</h2>
          <form class="order-form" hx-post="/ui/actions/orders" hx-target="#flash" hx-swap="innerHTML">
            <div class="field">
              <label for="assetCode">通貨</label>
              <select id="assetCode" name="assetCode">
                <option value="BTC">BTC</option>
                <option value="ETH">ETH</option>
              </select>
            </div>
            <div class="field">
              <label for="side">売買</label>
              <select id="side" name="side">
                <option value="buy">buy</option>
                <option value="sell">sell</option>
              </select>
            </div>
            <div class="field">
              <label for="timeInForce">Time in Force</label>
              <select id="timeInForce" name="timeInForce">
                <option value="SOK">SOK</option>
                <option value="FAS">FAS</option>
                <option value="FAK">FAK</option>
                <option value="FOK">FOK</option>
              </select>
            </div>
            <div class="field">
              <label for="priceJpy">価格(JPY)</label>
              <input id="priceJpy" name="priceJpy" placeholder="10000000" inputmode="decimal" required>
            </div>
            <div class="field">
              <label for="units">数量</label>
              <input id="units" name="units" placeholder="0.001" inputmode="decimal" required>
            </div>
            <div class="field" style="grid-column: 1 / -1;">
              <button class="primary" type="submit">注文作成</button>
            </div>
          </form>
        </section>

        <section class="panel">
          <h2>注文一覧</h2>
          <div
            hx-get="/ui/partials/orders"
            hx-trigger="load, refresh-all from:body, every 20s"
            hx-swap="innerHTML"
          >読込中...</div>
        </section>
      </div>

      <div class="stack">
        <section class="panel">
          <h2>最新残高</h2>
          <div
            hx-get="/ui/partials/balances"
            hx-trigger="load, refresh-all from:body, every 30s"
            hx-swap="innerHTML"
          >読込中...</div>
        </section>

        <section class="panel">
          <h2>最新価格</h2>
          <div
            hx-get="/ui/partials/prices"
            hx-trigger="load, refresh-all from:body, every 30s"
            hx-swap="innerHTML"
          >読込中...</div>
        </section>

        <section class="panel">
          <h2>ジョブ履歴</h2>
          <div
            hx-get="/ui/partials/jobs"
            hx-trigger="load, refresh-all from:body, every 20s"
            hx-swap="innerHTML"
          >読込中...</div>
        </section>
      </div>
    </div>
  </div>
</body>
</html>
{{end}}

{{define "flash"}}
<div class="flash {{.Kind}}">{{.Message}}</div>
{{end}}

{{define "summary"}}
<div class="cards">
  <div class="metric">
    <div class="label">サーバー時刻</div>
    <div class="value mono">{{.ServerTime}}</div>
  </div>
  <div class="metric">
    <div class="label">未解決注文</div>
    <div class="value">{{.OpenOrders}}</div>
  </div>
  <div class="metric">
    <div class="label">前日未解消</div>
    <div class="value">{{.UnresolvedPreviousDay}}</div>
  </div>
  <div class="metric">
    <div class="label">直近7日買い残枠</div>
    <div class="value mono">{{.WeeklyRemaining}}</div>
  </div>
</div>
{{end}}

{{define "balances"}}
<table>
  <thead>
    <tr><th>資産</th><th>利用可能</th><th>拘束中</th></tr>
  </thead>
  <tbody>
    {{range .Rows}}
    <tr>
      <td>{{.AssetCode}}</td>
      <td class="mono">{{.AvailableAmount}}</td>
      <td class="mono">{{.LockedAmount}}</td>
    </tr>
    {{else}}
    <tr><td colspan="3" class="muted">データがありません</td></tr>
    {{end}}
  </tbody>
</table>
{{end}}

{{define "prices"}}
<table>
  <thead>
    <tr><th>資産</th><th>価格(JPY)</th><th>取得時刻</th></tr>
  </thead>
  <tbody>
    {{range .Rows}}
    <tr>
      <td>{{.AssetCode}}</td>
      <td class="mono">{{.PriceJpy}}</td>
      <td class="mono">{{.CapturedAt}}</td>
    </tr>
    {{else}}
    <tr><td colspan="3" class="muted">データがありません</td></tr>
    {{end}}
  </tbody>
</table>
{{end}}

{{define "orders"}}
<table>
  <thead>
    <tr><th>ID</th><th>通貨</th><th>売買</th><th>価格</th><th>数量</th><th>状態</th><th></th></tr>
  </thead>
  <tbody>
    {{range .Rows}}
    <tr>
      <td class="mono">{{.ID}}</td>
      <td>{{.AssetCode}}</td>
      <td>{{.Side}}</td>
      <td class="mono">{{.PriceJpy}}</td>
      <td class="mono">{{.OrderedUnits}}</td>
      <td>{{.Status}}</td>
      <td>
        {{if .Cancelable}}
        <form hx-post="/ui/actions/orders/{{.ID}}/cancel" hx-target="#flash" hx-swap="innerHTML">
          <button class="danger" type="submit">取消</button>
        </form>
        {{end}}
      </td>
    </tr>
    {{else}}
    <tr><td colspan="7" class="muted">注文はありません</td></tr>
    {{end}}
  </tbody>
</table>
{{end}}

{{define "jobs"}}
<table>
  <thead>
    <tr><th>ID</th><th>種別</th><th>状態</th><th>開始</th><th>終了</th></tr>
  </thead>
  <tbody>
    {{range .Rows}}
    <tr>
      <td class="mono">{{.ID}}</td>
      <td>{{.JobType}}</td>
      <td>{{.Status}}</td>
      <td class="mono">{{.StartedAt}}</td>
      <td class="mono">{{.FinishedAt}}</td>
    </tr>
    {{else}}
    <tr><td colspan="5" class="muted">ジョブ履歴はありません</td></tr>
    {{end}}
  </tbody>
</table>
{{end}}
